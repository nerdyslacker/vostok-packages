# Template file for 'vostok-calamares-config'
pkgname=vostok-calamares-config
version=1.0
revision=85
archs="x86_64"

# Зависимости
depends="calamares calamares-extensions gptfdisk parted dosfstools util-linux e2fsprogs"

short_desc="Calamares configuration and branding for Vostok Linux"
maintainer="Vostok Linux <team@vostoklinux.org>"
license="GPL-3.0-or-later"
homepage="https://vostoklinux.org"

do_install() {
    # =====================
    # 1. Основные конфиги
    # =====================
    
    # settings.conf
    vmkdir etc/calamares
    vinstall "${FILESDIR}/etc/calamares/settings.conf" 644 etc/calamares/
    
    # Модули Calamares
    vmkdir etc/calamares/modules
    for conf in welcome locale keyboard partition users packages \
                 unpackfs bootloader networkcfg shellprocess_postinstall; do
        vinstall "${FILESDIR}/etc/calamares/modules/${conf}.conf" 644 \
                 etc/calamares/modules/
    done
    
    # =====================
    # 2. Брендинг Vostok
    # =====================
    
    # Директория брендинга
    vmkdir usr/share/calamares/branding/vostok
    
    # Файлы брендинга
    vinstall "${FILESDIR}/usr/share/calamares/branding/vostok/branding.desc" 644 \
             usr/share/calamares/branding/vostok/
    vinstall "${FILESDIR}/usr/share/calamares/branding/vostok/style.qss" 644 \
             usr/share/calamares/branding/vostok/
    vinstall "${FILESDIR}/usr/share/calamares/branding/vostok/welcome.qml" 644 \
             usr/share/calamares/branding/vostok/
    
    # Логотип (создаем простой, если нет)
    # Установка твоего реального логотипа
    vinstall "${FILESDIR}/usr/share/calamares/branding/vostok/vostok-logo.jpg" 644 \
             usr/share/calamares/branding/vostok/
    
    # =====================
    # 3. Кастомные модули
    # =====================
    
    
    # =====================
    # 4. Пост-установочные скрипты
    # =====================
    
    vmkdir var/lib/calamares/postinstall
     vinstall "${FILESDIR}/var/lib/calamares/postinstall/post-install.sh" 755 \
             var/lib/calamares/postinstall/
    
    # =====================
    # 5. Дополнительные настройки
    # =====================
    
    # Симлинк для удобства
    ln -sf /usr/share/calamares/branding/vostok \
           "${DESTDIR}/etc/calamares/branding" 2>/dev/null || true
}

post_install() {
    echo "========================================"
    echo " Vostok Calamares Config Установлен"
    echo "========================================"
    echo ""
    echo "Конфигурация:"
    echo "  • Основной конфиг: /etc/calamares/settings.conf"
    echo "  • Модули: /etc/calamares/modules/"
    echo "  • Брендинг: /usr/share/calamares/branding/vostok/"
    echo "  • Скрипты: /var/lib/calamares/postinstall/"
    echo ""
    echo "Для проверки: sudo calamares --check-config"
    echo "Для запуска:  sudo calamares -d"
    echo "========================================"
}