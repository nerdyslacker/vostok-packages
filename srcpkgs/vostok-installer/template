# Template file for vostok-installer
pkgname=vostok-installer
version=1.0
revision=20
# УБРАЛ metapackage и build_style совсем
depends="dialog xbps xmirror parted util-linux curl gptfdisk dosfstools e2fsprogs grub os-prober"
short_desc="Vostok Linux installation script"
maintainer="Vostok Linux Team <team@vostoklinux.org>"
license="BSD-2-Clause"
homepage="https://repo.vostoklinux.org"

do_install() {
    # Устанавливаем сам скрипт
    vinstall ${FILESDIR}/vostok-installer 755 usr/bin

    # Устанавливаем конфигурационные файлы
    if [ -f ${FILESDIR}/00-vostok-repository.conf ]; then
        vinstall ${FILESDIR}/00-vostok-repository.conf 644 etc/xbps.d
    fi

    # Устанавливаем desktop файл
    if [ -f ${FILESDIR}/vostok-installer.desktop ]; then
       vinstall ${FILESDIR}/vostok-installer.desktop 644 usr/share/applications
    fi

    # Иконка
    if [ -f ${FILESDIR}/vostok-installer.png ]; then
        vinstall ${FILESDIR}/vostok-installer.png 644 usr/share/icons/hicolor/48x48/apps
    fi

    # Лицензия
    vlicense ${FILESDIR}/vostok-installer # Если нет отдельного файла, можно указать сам скрипт как источник лицензии или создать файл как раньше
    vmkdir usr/share/licenses/${pkgname}
    echo "Vostok Linux Installer License" > ${DESTDIR}/usr/share/licenses/${pkgname}/LICENSE
}

