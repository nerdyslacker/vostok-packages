# srcpkgs/vostok-release/template
pkgname=vostok-release
version=1.0
revision=5
archs="x86_64"
short_desc="Vostok Linux release branding"
maintainer="Vostok Linux <team@vostoklinux.org>"
license="BSD-2-Clause"
homepage="https://vostoklinux.org"

# ✅ Ключевые строки: "мягкая" замена base-files и полная замена void-release
replaces="base-files>=0 void-release>=0"
conflicts="void-release"
provides="void-release-1.0_1"

# ✅ Зависям от base-files, чтобы гарантировать установку базовой структуры каталогов
depends="base-files vostok-mirrorlist vostok-logo bash"

do_install() {
    # Просто устанавливаем наши файлы поверх base-files
    vinstall ${FILESDIR}/os-release 644 etc
    vinstall ${FILESDIR}/issue 644 etc
    vmkdir usr/lib
    ln -sf ../etc/os-release ${DESTDIR}/usr/lib/os-release
}