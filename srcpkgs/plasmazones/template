post_install() {
	vmkdir etc/xdg/autostart
	vinstall ${FILESDIR}/plasmazones-start.desktop 644 etc/xdg/autostart

    # Remove systemd service files
    rm -rf ${DESTDIR}/usr/lib/systemd/
}
