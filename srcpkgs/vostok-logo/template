pkgname=vostok-logo
version=1.1
revision=10
archs="x86_64"
short_desc="Vostok Linux branding and Fastfetch configuration"
maintainer="Vostok Linux team <vostoklinux.org>"
license="CC-BY-SA-4.0"
homepage="https://vostoklinux.org"
depends="fastfetch"
triggers="gtk-icon-cache"

do_install() {
	# 1. Установка графических логотипов
	vinstall "${FILESDIR}/vostok-logo.png" 644 usr/share/pixmaps
	ln -sf vostok-logo.png "${DESTDIR}/usr/share/pixmaps/distributor-logo.png"
	
	# Кладем PNG в правильную директорию для растра
	vmkdir usr/share/icons/hicolor/48x48/apps
	vinstall "${FILESDIR}/vostok-logo.png" 644 usr/share/icons/hicolor/48x48/apps
	ln -sf vostok-logo.png "${DESTDIR}/usr/share/icons/hicolor/48x48/apps/distributor-logo.png"
	ln -sf vostok-logo.png "${DESTDIR}/usr/share/icons/hicolor/48x48/apps/start-here-kde.png"

	# 2. КОНФИГ ДЛЯ KDE PLASMA (О системе)
	vmkdir etc/xdg
	cat <<-EOF > "${DESTDIR}/etc/xdg/kcm-about-distrorc"
	[General]
	LogoPath=/usr/share/pixmaps/vostok-logo.png
	Name=Vostok Linux
	Website=https://vostoklinux.org
	EOF
	
	# ПРИНУДИТЕЛЬНАЯ ИКОНКА ДЛЯ МЕНЮ (для новых юзеров)
	vmkdir etc/skel/.config
	cat <<-EOF > "${DESTDIR}/etc/skel/.config/plasmarc"
	[PlasmaViews][Panel 1][Defaults]
	launcherIcon=/usr/share/icons/hicolor/48x48/apps/vostok-logo.png
	EOF

	# 3. Установка ASCII логотипа
	vmkdir usr/share/vostok
	vinstall "${FILESDIR}/vostok-ascii.txt" 644 usr/share/vostok

	# 4. Глобальный конфиг Fastfetch
	vmkdir etc/fastfetch
	cat <<-EOF > "${DESTDIR}/etc/fastfetch/config.jsonc"
	{
	    "logo": {
	        "source": "/usr/share/vostok/vostok-ascii.txt",
	        "type": "auto",
	        "padding": { "top": 3, "left": 3 }
	    },
	    "modules": [ "title", "separator", "os", "host", "kernel", "uptime", "packages", "shell", "display", "de", "wm", "terminal", "cpu", "gpu", "memory", "break", "colors" ]
	}
	EOF

	# 5. Скрипт обновления конфигов (Fastfetch + Icon для David)
	vmkdir usr/libexec/vostok
	cat <<-EOF > "${DESTDIR}/usr/libexec/vostok/apply-vostok.sh"
	#!/bin/sh
	for user_home in /home/* /root; do
	    [ ! -d "\$user_home" ] && continue
	    USER_NAME=\$(basename "\$user_home")
	    
	    # Fastfetch
	    mkdir -p "\$user_home/.config/fastfetch"
	    cp -f /etc/fastfetch/config.jsonc "\$user_home/.config/fastfetch/config.jsonc"
	    
	    # KDE Menu Icon (замена иконки в живой системе)
	    PLASMA_APPLET_CONFIG="\$user_home/.config/plasma-org.kde.plasma.desktop-appletsrc"
	    if [ -f "\$PLASMA_APPLET_CONFIG" ]; then
	        sed -i 's|icon=.*|icon=/usr/share/icons/hicolor/48x48/apps/vostok-logo.png|g' "\$PLASMA_APPLET_CONFIG"
	    fi

	    if [ "\$USER_NAME" = "root" ]; then
	        chown -R root:root "\$user_home/.config"
	    else
	        chown -R "\$USER_NAME:\$USER_NAME" "\$user_home/.config"
	    fi
	done
	EOF
	chmod 755 "${DESTDIR}/usr/libexec/vostok/apply-vostok.sh"
}

post_install() {
	/usr/libexec/vostok/apply-vostok.sh 2>/dev/null || true
	echo -e "\n\033[1;34m[Vostok Linux]\033[0m Брендинг применен. Перезайдите в KDE, чтобы увидеть иконку!"
}
