#!/bin/bash
# vostok-gum-installer — Vostok Linux TUI Installer (gum edition)

set -e

# Цвета Vostok (голубой)
export GUM_COLOR=39
export GUM_INPUT_PROMPT_FOREGROUND=39

# Приветствие
gum style \
    --border double \
    --border-foreground 39 \
    --padding "1 2" \
    --margin 1 \
    --align center \
    "Vostok Linux 1.0 Workstation" \
    "Голубая мечта становится реальностью"

# Проверка root
if [ "$EUID" -ne 0 ]; then
    gum log --level fatal "Запустите установщик с правами root"
    exit 1
fi

# Проверка Live-режима
if [ ! -f /run/initramfs/live ]; then
    gum log --level fatal "Установщик должен запускаться из Live-системы"
    exit 1
fi

# 1. Выбор диска — gum filter с живым поиском
gum log --level info "Сканирование доступных дисков..."
DISKS=$(lsblk -d -o NAME,SIZE,MODEL -n | grep -v loop)
if [ -z "$DISKS" ]; then
    gum log --level fatal "Не найдено ни одного диска"
    exit 1
fi

SELECTED=$(echo "$DISKS" | gum filter --header "Выберите целевой диск:" --height 10)
DISK_DEVICE="/dev/$(echo "$SELECTED" | awk '{print $1}')"

gum log --level info "Выбран диск: $DISK_DEVICE"

# 2. Подтверждение с предупреждением
gum confirm \
    --prompt.foreground 196 \
    --selected.background 39 \
    --selected.foreground 0 \
    "⚠️  ВСЕ ДАННЫЕ НА $DISK_DEVICE БУДУТ УДАЛЕНЫ! Продолжить?" \
    --affirmative "Да, ставь!" \
    --negative "Нет, выйти" || exit 1

# 3. Выбор файловой системы
FS=$(gum choose \
    --header "Выберите файловую систему для корневого раздела:" \
    --cursor "▶ " \
    --selected.foreground 39 \
    "ext4 (рекомендуется)" \
    "btrfs (со снапшотами)" \
    "xfs (для больших файлов)" \
    "f2fs (для SSD)")

gum log --level info "Выбрана ФС: $FS"

# 4. Имитация установки — здесь будет реальная логика
gum spin --spinner pulse --title "Подготовка диска..." -- sleep 2
gum spin --spinner dot --title "Копирование системы..." -- sleep 3
gum spin --spinner monkey --title "Настройка загрузчика..." -- sleep 2

# 5. Успешное завершение
gum style \
    --border rounded \
    --border-foreground 39 \
    --foreground 39 \
    --padding "1 2" \
    --align center \
    "✅ Vostok Linux успешно установлен!"

gum confirm "Перезагрузить компьютер?" \
    --affirmative "Да" \
    --negative "Остаться в Live" && reboot