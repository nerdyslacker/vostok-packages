# Template file for vostok-gum-installer
pkgname=vostok-gum-installer
version=1.0
revision=1
depends="gum xbps xmirror parted util-linux curl gptfdisk dosfstools e2fsprogs grub os-prober"
short_desc="Vostok Linux graphical TUI installer (gum edition)"
maintainer="Vostok Linux Team <team@vostoklinux.org>"
license="BSD-2-Clause"
homepage="https://repo.vostoklinux.org"

do_install() {
    # Устанавливаем скрипт gum-версии под другим именем
    vinstall ${FILESDIR}/vostok-gum-installer 755 usr/bin

    # Конфигурация репозитория (можно использовать ту же)
    vinstall ${FILESDIR}/00-vostok-repository.conf 644 etc/xbps.d

    # Desktop файл с изменённым названием
    vinstall ${FILESDIR}/vostok-gum-installer.desktop 644 usr/share/applications

    # Иконка (можно ту же, либо сделать отличия)
    vinstall ${FILESDIR}/vostok-gum-installer.png 644 usr/share/icons/hicolor/48x48/apps

    # Лицензия
    vmkdir usr/share/licenses/${pkgname}
    echo "Vostok Linux Installer (gum edition) - same license as original" > \
        ${DESTDIR}/usr/share/licenses/${pkgname}/LICENSE
}